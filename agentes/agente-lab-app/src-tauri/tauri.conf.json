{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Agente de Laboratorio",
  "version": "1.0.0",
  "identifier": "com.centroesperanza.agente-lab",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Agente de Laboratorio — Centro Médico Esperanza",
        "width": 1000,
        "height": 680,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "sidecar/agente-lab"
    ],
    "resources": [
      "resources/config.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Spanish"],
        "installMode": "perMachine",
        "minimumWebview2Version": "2.0.0"
      }
    }
  }
}
