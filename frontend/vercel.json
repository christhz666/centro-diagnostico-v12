{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "${BACKEND_URL}/api/$1",
      "env": ["BACKEND_URL"]
    },
    {
      "src": "/uploads/(.*)",
      "dest": "${BACKEND_URL}/uploads/$1",
      "env": ["BACKEND_URL"]
    },
    {
      "src": "/public/(.*)",
      "dest": "${BACKEND_URL}/public/$1",
      "env": ["BACKEND_URL"]
    }
  ]
}
