{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Centro Médico Esperanza",
  "version": "1.0.0",
  "identifier": "com.centroesperanza.desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Centro Médico Esperanza",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "es-ES",
        "bannerPath": "../public/Logo-Mie-esperanza-Lab-Color-400x190-1.png",
        "dialogImagePath": "../public/Logo-Mie-esperanza-Lab-Color-400x190-1.png"
      }
    },
    "resources": []
  }
}