{
  "name": "centro-diagnostico-backend",
  "version": "1.0.0",
  "description": "Backend API - Plataforma SaaS de Centro Diagnóstico",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "cd frontend && npm install && npm start",
    "dev": "cd frontend && npm install && npm start",
    "backend": "node server.js",
    "backend:dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "env:prepare:prod": "node scripts/prepareProductionEnv.js",
    "template:saas:clean": "node scripts/cleanSaasTemplate.js",
    "provision:saas": "bash scripts/provision-saas.sh",
    "release:gate": "node scripts/releaseGate.js",
    "migrate:factura-password-hash": "node scripts/migrateFacturaPasswordHash.js",
    "build:backend": "pkg . --targets node18-win-x64 --output frontend/src-tauri/bin/backend-x86_64-pc-windows-msvc.exe",
    "frontend:build": "cd frontend && npm run build",
    "tauri:dev": "cd frontend && npx tauri dev",
    "tauri:build": "cd frontend && npx tauri build"
  },
  "pkg": {
    "scripts": [
      "controllers/**/*.js",
      "models/**/*.js",
      "routes/**/*.js",
      "middleware/**/*.js",
      "services/**/*.js",
      "config/**/*.js",
      "utils/**/*.js"
    ],
    "assets": [
      "public/**/*"
    ]
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.4",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.9.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^5.12.2",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xss-clean": "^0.1.4"
  },
  "optionalDependencies": {
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1",
    "supertest": "^6.3.3"
  }
}
